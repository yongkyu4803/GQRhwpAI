# AI 채팅 편집 기능 인증. 아래 둘 중 하나를 .env.local 에 설정하세요.
# (cp .env.example .env.local)

# ── 권장: 구독제(Claude Pro/Max) 인증 ──
# 터미널에서 아래 명령으로 장기 토큰을 발급받아 붙여넣으세요:
#   claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# ── 대안: API 키(사용량 과금) ──
# 구독 토큰이 없을 때만 사용됩니다. (구독 토큰이 있으면 이 값은 무시됩니다.)
# ANTHROPIC_API_KEY=sk-ant-...

# (선택) 에이전트가 사용할 모델. 기본값: claude-opus-4-8
# HWP_AGENT_MODEL=claude-opus-4-8
